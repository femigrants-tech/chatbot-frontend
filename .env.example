# Backend API
VITE_API_BASE_URL=https://femigrants-chatbot-backend.vercel.app
VITE_AI_MODEL=gemini-2.5-flash

# Admin login for /files (required for file management access)
VITE_ADMIN_USER_ID=admin
VITE_ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: separate secret for signing admin sessions (recommended in production)
VITE_AUTH_SESSION_SECRET=generate-a-long-random-string
